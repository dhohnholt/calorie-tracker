# Copy this file to .env and set your machine's LAN IP address.
#
# - iOS Simulator: localhost works, since the simulator shares the Mac's
#   network stack. The app already defaults to http://localhost:3001/api
#   when this is unset, so a .env file is optional for simulator-only use.
# - Physical iPhone on the same Wi-Fi network: localhost refers to the
#   phone itself, not your Mac, so it will NOT reach the server. Find your
#   Mac's LAN IP (System Settings > Wi-Fi > Details, or `ipconfig getifaddr en0`
#   in a terminal) and use that instead.
#
# Never commit a real .env file — this .example file is the only one tracked.

EXPO_PUBLIC_API_URL=http://192.168.1.100:3001/api
