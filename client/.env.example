# Copy to .env to override which API server the Vite dev proxy targets.
#
# Unset (no .env file): defaults to http://localhost:3001, the local server —
# safest for local feature development, never touches real deployed data.
#
# Point this at the deployed Railway server so the web app and mobile app
# read/write the same data:
VITE_API_PROXY_TARGET=https://your-railway-url.up.railway.app
